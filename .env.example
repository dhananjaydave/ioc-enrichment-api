# Copy to .env. Both keys are optional - missing ones just get skipped
# (response still works, with that source marked "skipped").

# Free at https://www.virustotal.com/gui/join-us
VIRUSTOTAL_API_KEY=

# Free at https://www.abuseipdb.com/register
ABUSEIPDB_API_KEY=

# How long to cache a lookup result before re-checking (seconds).
CACHE_TTL_SECONDS=3600

# Optional - if set, /enrich requires a matching X-API-Key header. Strongly
# recommended if you deploy this publicly, otherwise anyone can burn through
# your VirusTotal/AbuseIPDB quota.
IOC_API_KEY=
